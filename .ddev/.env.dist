# Copy to .ddev/.env and fill in. DDEV auto-loads .ddev/.env into compose substitution
# and (via config.yaml web_environment) into the web container. Dev-only convenience;
# production stores provider keys via the nr-vault extension, not env vars.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
FAL_API_KEY=
